# LINE Credentials
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_OA_URL=https://line.me/ti/p/~your-oa

# AI Provider Keys
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
QWEN_API_KEY=sk-...

# OpenCode Settings
OPENCODE_URL=http://opencode:4096
OPENCODE_PASSWORD=your_password
OPENCODE_DIR=/workspace

# Server
PORT=3000
PROMPT_TIMEOUT_MS=120000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# GitHub (optional, for gh CLI in OpenCode container)
GITHUB_TOKEN=ghp_...
